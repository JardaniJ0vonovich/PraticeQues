#! /usr/bin/vvp
:ivl_version "11.0 (stable)";
:ivl_delay_selection "TYPICAL";
:vpi_time_precision + 0;
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/system.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_sys.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_textio.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/v2005_math.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/va_math.vpi";
S_0x5586fdc08160 .scope module, "counter_tb" "counter_tb" 2 1;
 .timescale 0 0;
v0x5586fdc30530_0 .var "clk", 0 0;
v0x5586fdc305d0_0 .var "in", 6 0;
v0x5586fdc30670_0 .var "ld", 0 0;
v0x5586fdc30770_0 .net "out", 6 0, v0x5586fdc2fda0_0;  1 drivers
v0x5586fdc30840_0 .var "rst", 0 0;
S_0x5586fdc1a100 .scope module, "DUT" "counter" 2 6, 3 1 0, S_0x5586fdc08160;
 .timescale 0 0;
    .port_info 0 /INPUT 7 "in";
    .port_info 1 /INPUT 1 "ld";
    .port_info 2 /INPUT 1 "rst";
    .port_info 3 /INPUT 1 "clk";
    .port_info 4 /OUTPUT 7 "out";
v0x5586fdbe1ba0_0 .net "clk", 0 0, v0x5586fdc30530_0;  1 drivers
v0x5586fdc06ae0_0 .net "in", 6 0, v0x5586fdc305d0_0;  1 drivers
v0x5586fdbe1350_0 .net "ld", 0 0, v0x5586fdc30670_0;  1 drivers
v0x5586fdc2fda0_0 .var "out", 6 0;
v0x5586fdc2fe80_0 .net "rst", 0 0, v0x5586fdc30840_0;  1 drivers
E_0x5586fdbe08d0 .event posedge, v0x5586fdbe1ba0_0;
S_0x5586fdc30030 .scope task, "load" "load" 2 25, 2 25 0, S_0x5586fdc08160;
 .timescale 0 0;
v0x5586fdc30250_0 .var "a", 6 0;
E_0x5586fdc18da0 .event negedge, v0x5586fdbe1ba0_0;
TD_counter_tb.load ;
    %wait E_0x5586fdc18da0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5586fdc30670_0, 0, 1;
    %load/vec4 v0x5586fdc30250_0;
    %store/vec4 v0x5586fdc305d0_0, 0, 7;
    %wait E_0x5586fdc18da0;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5586fdc30670_0, 0, 1;
    %pushi/vec4 0, 0, 7;
    %store/vec4 v0x5586fdc305d0_0, 0, 7;
    %end;
S_0x5586fdc30350 .scope task, "reset" "reset" 2 16, 2 16 0, S_0x5586fdc08160;
 .timescale 0 0;
TD_counter_tb.reset ;
    %wait E_0x5586fdc18da0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5586fdc30840_0, 0, 1;
    %wait E_0x5586fdc18da0;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5586fdc30840_0, 0, 1;
    %end;
    .scope S_0x5586fdc1a100;
T_2 ;
    %wait E_0x5586fdbe08d0;
    %load/vec4 v0x5586fdc2fe80_0;
    %flag_set/vec4 8;
    %jmp/0xz  T_2.0, 8;
    %pushi/vec4 75, 0, 7;
    %assign/vec4 v0x5586fdc2fda0_0, 0;
    %jmp T_2.1;
T_2.0 ;
    %load/vec4 v0x5586fdbe1350_0;
    %flag_set/vec4 8;
    %jmp/0xz  T_2.2, 8;
    %load/vec4 v0x5586fdc06ae0_0;
    %assign/vec4 v0x5586fdc2fda0_0, 0;
    %jmp T_2.3;
T_2.2 ;
    %load/vec4 v0x5586fdc2fda0_0;
    %cmpi/e 78, 0, 7;
    %jmp/0xz  T_2.4, 4;
    %pushi/vec4 75, 0, 7;
    %assign/vec4 v0x5586fdc2fda0_0, 0;
    %jmp T_2.5;
T_2.4 ;
    %load/vec4 v0x5586fdc2fda0_0;
    %addi 1, 0, 7;
    %assign/vec4 v0x5586fdc2fda0_0, 0;
T_2.5 ;
T_2.3 ;
T_2.1 ;
    %jmp T_2;
    .thread T_2;
    .scope S_0x5586fdc08160;
T_3 ;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5586fdc30530_0, 0, 1;
    %delay 5, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5586fdc30530_0, 0, 1;
    %delay 5, 0;
    %jmp T_3;
    .thread T_3;
    .scope S_0x5586fdc08160;
T_4 ;
    %fork TD_counter_tb.reset, S_0x5586fdc30350;
    %join;
    %delay 20, 0;
    %pushi/vec4 76, 0, 7;
    %store/vec4 v0x5586fdc30250_0, 0, 7;
    %fork TD_counter_tb.load, S_0x5586fdc30030;
    %join;
    %delay 70, 0;
    %vpi_call 2 42 "$finish" {0 0 0};
    %end;
    .thread T_4;
    .scope S_0x5586fdc08160;
T_5 ;
    %vpi_call 2 47 "$dumpfile", "waveform.vcd" {0 0 0};
    %vpi_call 2 48 "$dumpvars", 32'sb00000000000000000000000000000000, S_0x5586fdc08160 {0 0 0};
    %end;
    .thread T_5;
# The file index is used to find the file name in the following table.
:file_names 4;
    "N/A";
    "<interactive>";
    "counter_tb.v";
    "counter.v";
